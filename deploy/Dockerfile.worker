# Build context = repository root.
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY backend/ ./
RUN dotnet publish src/Hosts/IndustryTrade.Worker/IndustryTrade.Worker.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app ./
ENTRYPOINT ["dotnet", "IndustryTrade.Worker.dll"]
