# Copy to .env and adjust for your environment. NEVER commit the real .env.

# Public address browsers use to reach this server (IP or hostname, no port/scheme).
# Local: leave as localhost. Remote demo: set to the server's public IP/hostname,
# e.g. PUBLIC_HOST=203.0.113.10  — then open the app at http://<PUBLIC_HOST>:8081
PUBLIC_HOST=localhost

POSTGRES_DB=industrytrade
POSTGRES_USER=itrade
POSTGRES_PASSWORD=itrade_dev_pw

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
